# Neon Postgres connection string
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgres://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require

# Protects /api/cron. cron-job.org sends this as: Authorization: Bearer <secret>
# Generate: openssl rand -base64 32
CRON_SECRET=replace-me-with-a-random-secret

# MapTiler API key for basemap tiles (free tier, no credit card required)
# Sign up at https://maptiler.com → account → API keys
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key-here
